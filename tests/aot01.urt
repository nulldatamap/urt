define {
  comment { drop }
  mod-clamp {
    locals { x } {
      choose
        { + 100 }
        {}
        > 0 dup
        % x 100
    }
  }
  step {
    locals { acc data } {
      mod-clamp
      choose
        { - acc head-tail }
        { + acc head-tail }
        = :L head-tail data
    }
  }
  solve-helper {
    locals { zeroes acc data } {
      choose
        { locals { new-acc new-data }
          { solve-helper
              choose
                { + 1 zeroes }
                { zeroes }
                = 0 new-acc
              new-acc
              new-data }
          step acc data }
        { zeroes }
        data
    }
  }
  solve { solve-helper 0 50 }
}
